{
  "manifest_version": 3,
  "name": "Jira Estimate Summary",
  "version": "1.0.0",
  "description": "Sum Original estimate hours per Jira board column and highlight cards without an estimate. Time tracking helper for Scrum/Kanban.",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Jira Estimate Summary",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.atlassian.net/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["src/net/interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://*.atlassian.net/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "src/estimate.js",
        "src/settings.js",
        "src/store.js",
        "src/board.js",
        "src/net/board-api.js",
        "src/net/board-fetch.js",
        "src/content.js"
      ],
      "css": ["src/styles.css"],
      "run_at": "document_idle"
    }
  ]
}
