{
  "manifest_version": 3,
  "name": "Jira Estimate Summary",
  "version": "1.0.0",
  "description": "Суммирует Original estimate по каждой колонке Jira-доски, переводит время в часы и подсвечивает карточки без оценки.",
  "permissions": ["storage"],
  "action": {
    "default_title": "Jira Estimate Summary",
    "default_popup": "src/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.atlassian.net/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["src/net/interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://*.atlassian.net/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "src/estimate.js",
        "src/settings.js",
        "src/store.js",
        "src/board.js",
        "src/net/board-api.js",
        "src/net/board-fetch.js",
        "src/content.js"
      ],
      "css": ["src/styles.css"],
      "run_at": "document_idle"
    }
  ]
}
